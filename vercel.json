{
    "version": 2,
    "functions": {
        "server/index.ts": {
            "includeFiles": "dist/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "server/index.ts"
        },
        {
            "source": "/ws/(.*)",
            "destination": "server/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "server/index.ts"
        }
    ]
}